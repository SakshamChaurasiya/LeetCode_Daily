//Brute Force T: O(n^2)  S: O(1)
class Solution {
    public int numOfSubarrays(int[] arr, int k, int threshold) {
        int maxT = k * threshold;
        int count = 0;
        int n = arr.length;

        for (int i = 0; i <= n - k; i++) {
            int sum = 0;
            for (int j = i; j < i + k; j++) {
                sum = sum + arr[j];
            }
            if (sum >= maxT) {
                count++;
            }
        }
        return count;
    }
}

