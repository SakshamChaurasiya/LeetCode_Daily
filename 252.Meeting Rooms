//Brute Force T: O(n^2)  S: O(1)
class Solution {
    static boolean canAttend(int[][] arr) {
        // code here
        for(int i=0;i<arr.length;i++){
            int s1= arr[i][0],
                e1 = arr[i][1]-1;
            for(int j=i+1;j<arr.length;j++){
            int s2= arr[j][0],
                    e2 = arr[j][1]-1;
                if(e1>=s2 && e2>=s1){
                    return false;
                }
            }
        }
        return true;
    }
}

//Approach 2(Optimized) T: O(n.logn)  S: O(depends on programming language sorting)
 class Solution {
    static boolean canAttend(int[][] arr) {
        Arrays.sort(arr,(a,b)->Integer.compare(a[0],b[0]));
        for(int i=1;i<arr.length;i++){
            if(arr[i][0]<arr[i-1][1]){
                return false;
            }
        }
        return true;
    }
}
