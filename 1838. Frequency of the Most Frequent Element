class Solution {
    public int maxFrequency(int[] nums, int k) {
        Arrays.sort(nums);
        int max = 0;

        long sum = 0;
        int i = 0,
                j = 0;

        while (j < nums.length) {
            sum = sum + nums[j];

            while ((((j - i + 1) * (long)nums[j]) - sum) > k) {
                sum=sum-nums[i];
                i++;
            }

             max = Math.max(max, j - i + 1);
             j++;
               
            }
        return max;
    }
}
