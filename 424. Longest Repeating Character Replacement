//Brute Force (T: O(n^2  S: O(1))
class Solution {
    public int characterReplacement(String s, int k) {
        int max = 0;
        for (int i = 0; i < s.length(); i++) {
            int maxC = 0;
            int[] counts = new int[26];
            for (int j = i; j < s.length(); j++) {
                char c = s.charAt(j);
                counts[c - 'A'] = counts[c - 'A'] + 1;
                maxC = Math.max(maxC, counts[c - 'A']);

                int ops = (j - i + 1) - maxC;

                if (ops > k) {
                    break;
                }
                max = Math.max(max, j - i + 1);
            }
        }

        return max;
    }
}

//Optimized(Sliding Window  T: O(n) S: O(1)) 
class Solution {
    public int characterReplacement(String s, int k) {
        //AABABBA
        //i
        //    j
        //counts={A:3,B:2}
        //maxC=3
        //l=5
        //op=2
        //max=4

        int max = 0;
        int i = 0,
                j = 0;
        int[] counts = new int[26];
        int maxC = 0;
        while (j < s.length()) {
            char c = s.charAt(j);
            counts[c - 'A'] = counts[c - 'A'] + 1;
            maxC = Math.max(maxC, counts[c - 'A']);

            int ops = (j - i + 1) - maxC;

            if (ops > k) {
                char p = s.charAt(i);
                counts[p - 'A'] = counts[p - 'A'] - 1;
                i++;
            }
            max = Math.max(max, j - i + 1);
            j++;
        }

        return max;
    }
}
