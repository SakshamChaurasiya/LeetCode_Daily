class SummaryRanges {
    List<Integer> list;

//T: (1) S: O(1)
    public SummaryRanges() {
        list = new ArrayList<Integer>();
    }

//One call-> T: O(n)  S: O(1)
//m calls-> T: O(m.n)  S: O(m)
    public void addNum(int value) {
        if (!list.contains(value)) {
            list.add(value);
        }
    }

//One call-> T: O(n.logn)  S: O(n)
//m calls-> T: O(m.n.logn)  S: O(n)
    public int[][] getIntervals() {
        if (list.size() == 0) {
            return new int[][] {};
        }

        Collections.sort(list);

        Integer left = null,
                right = null;

        List<int[]> res = new ArrayList<>();

        for (int i = 0; i < list.size(); i++) {
            if (left == null && right == null) {
                left = list.get(i);
                right = list.get(i);
            } else if (right + 1 == list.get(i)) {
                right = list.get(i);
            } else {
                res.add(new int[] {
                        left,
                        right
                });
                left = list.get(i);
                right = list.get(i);
            }
        }
        res.add(new int[] {
                left,
                right
        });

        int[][] ans = new int[res.size()][2];

        for (int i = 0; i < res.size(); i++) {
            ans[i] = res.get(i);
        }

        return ans;
    }
}

